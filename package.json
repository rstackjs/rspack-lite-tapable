{
  "name": "@rspack/lite-tapable",
  "version": "1.1.1",
  "repository": "https://github.com/rstackjs/rspack-lite-tapable",
  "license": "MIT",
  "description": "Lite weight tapable for Rspack",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "pnpx bumpp"
  },
  "files": [
    "dist"
  ],
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "@rslib/core": "^0.21.5",
    "@rslint/core": "^0.5.3",
    "@rspack/core": "^2.0.4",
    "@rstest/core": "0.10.2",
    "@types/node": "^24.12.4",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.3.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
